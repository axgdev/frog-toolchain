From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: frog-toolchain <frog-toolchain@local>
Date: Mon, 27 Apr 2026 00:00:00 +0000
Subject: [PATCH] gcc/mips: add mipsfrog pseudo CPU

Add a pseudo CPU for the SF2000/GB300 target hardware.  The SoC accepts
some MIPS32r2 instructions, but hardware testing showed that several r2
opcodes are either unimplemented or incorrectly decoded:

  - seb, seh, wsbh and rdhwr raise reserved-instruction exceptions
  - rotr and rotrv execute as logical right shifts instead of rotates

Other useful r2-era instructions such as ext, ins, clz, clo, mul,
madd, maddu, msub, msubu, movn, movz and sync passed the hardware
probe.  Model this as a MIPS32r2-derived CPU that disables only the
unsafe GCC-generated instructions, while still allowing the backend to
use the verified subset.

Map assembler input back to -march=mips32r2 because binutils does not
know this GCC-only pseudo CPU name.  GCC is responsible for withholding
the unsafe instructions before assembly.
---
 gcc/config/mips/mips-cpus.def |  6 ++++++
 gcc/config/mips/mips.cc       |  5 ++++-
 gcc/config/mips/mips.h        | 28 ++++++++++++++++++++--------
 3 files changed, 30 insertions(+), 9 deletions(-)

diff --git a/gcc/config/mips/mips-cpus.def b/gcc/config/mips/mips-cpus.def
index 0b69ee7b1b0..e42eedc40c7 100644
--- a/gcc/config/mips/mips-cpus.def
+++ b/gcc/config/mips/mips-cpus.def
@@ -99,6 +99,12 @@ MIPS_CPU ("4kp", PROCESSOR_4KP, MIPS_ISA_MIPS32, 0)
 MIPS_CPU ("4ksc", PROCESSOR_4KC, MIPS_ISA_MIPS32, 0)
 
 /* MIPS32 Release 2 processors.  */
+/* SF2000/GB300 pseudo CPU.  Hardware probes confirm a useful MIPS32r2
+   subset, but seb/seh/wsbh/rdhwr trap and rotr/rotrv are misdecoded as
+   logical right shifts.  GCC keeps the verified r2 subset enabled and
+   disables the unsafe instructions through TARGET_MIPSFROG checks.  */
+MIPS_CPU ("mipsfrog", PROCESSOR_24KC, MIPS_ISA_MIPS32R2, PTF_AVOID_BRANCHLIKELY_ALWAYS)
+
 MIPS_CPU ("m4k", PROCESSOR_M4K, MIPS_ISA_MIPS32R2, 0)
 MIPS_CPU ("m14kc", PROCESSOR_M4K, MIPS_ISA_MIPS32R2, 0)
 MIPS_CPU ("m14k", PROCESSOR_M4K, MIPS_ISA_MIPS32R2, 0)
diff --git a/gcc/config/mips/mips.cc b/gcc/config/mips/mips.cc
index c76adddd7f5..b5b8445af3f 100644
--- a/gcc/config/mips/mips.cc
+++ b/gcc/config/mips/mips.cc
@@ -10338,3 +10338,6 @@ mips_file_start (void)
 
-  fprintf (asm_out_file, "\t.module\tarch=%s\n", mips_arch_info->name);
+  if (TARGET_MIPSFROG)
+    fputs ("\t.module\tarch=mips32r2\n", asm_out_file);
+  else
+    fprintf (asm_out_file, "\t.module\tarch=%s\n", mips_arch_info->name);
  /* FIXME: DSPR3 is not supported by GCC? gas does support it */
diff --git a/gcc/config/mips/mips.h b/gcc/config/mips/mips.h
index f9f9730561e..b25c9c71a0a 100644
--- a/gcc/config/mips/mips.h
+++ b/gcc/config/mips/mips.h
@@ -829,7 +829,7 @@ struct mips_cpu_info {
      %{march=mips32|march=4kc|march=4km|march=4kp|march=4ksc:-mips32} \
      %{march=mips32r2|march=m4k|march=4ke*|march=4ksd|march=24k* \
        |march=34k*|march=74k*|march=m14k*|march=1004k* \
-       |march=interaptiv: -mips32r2} \
+       |march=interaptiv|march=mipsfrog: -mips32r2} \
      %{march=mips32r3: -mips32r3} \
      %{march=mips32r5|march=p5600|march=m5100|march=m5101: -mips32r5} \
      %{march=mips32r6: -mips32r6} \
@@ -855,7 +855,9 @@ struct mips_cpu_info {
 #define MIPS_ARCH_FLOAT_SPEC \
-  "%{mhard-float|msoft-float|mno-float|march=mips*:; \
+  "%{mhard-float|msoft-float|mno-float \
+     |march=mips1|march=mips2|march=mips3|march=mips4 \
+     |march=mips32*|march=mips64*:; \
      march=vr41*|march=m4k|march=4k*|march=24kc|march=24kec \
-     |march=34kc|march=34kn|march=74kc|march=1004kc|march=5kc \
+     |march=34kc|march=34kn|march=74kc|march=1004kc|march=5kc|march=mipsfrog \
      |march=m14k*|march=m5101|march=octeon|march=xlr: -msoft-float; \
      march=*: -mhard-float}"
 
@@ -874,8 +874,9 @@ struct mips_cpu_info {
 /* Infer a -msynci setting from a -mips argument, on the assumption that
    -msynci is desired where possible.  */
 #define MIPS_ISA_SYNCI_SPEC \
-  "%{msynci|mno-synci:;:%{mips32r2|mips32r3|mips32r5|mips32r6|mips64r2 \
-			  |mips64r3|mips64r5|mips64r6:-msynci;:-mno-synci}}"
+  "%{msynci|mno-synci:;:%{march=mipsfrog:-mno-synci; \
+     mips32r2|mips32r3|mips32r5|mips32r6|mips64r2 \
+     |mips64r3|mips64r5|mips64r6:-msynci;:-mno-synci}}"
 
 /* Infer a -mnan=2008 setting from a -mips argument.  */
 #define MIPS_ISA_NAN2008_SPEC \
@@ -994,6 +995,10 @@ struct mips_cpu_info {
 				 && Pmode == DImode	\
 				 && !TARGET_SYM32)
 
+/* True when targeting the SF2000/GB300 verified MIPS32r2 subset.  */
+#define TARGET_MIPSFROG \
+  (mips_arch_info && strcmp (mips_arch_info->name, "mipsfrog") == 0)
+
 /* ISA has instructions for managing 64-bit fp and gp regs (e.g. mips3).  */
 #define ISA_HAS_64BIT_REGS	(ISA_MIPS3				\
 				 || ISA_MIPS4				\
@@ -1245,11 +1250,13 @@ struct mips_cpu_info {
 				  || TARGET_MIPS5500			\
 				  || TARGET_SR71K			\
 				  || TARGET_SMARTMIPS)			\
-				 && !TARGET_MIPS16)
+				 && !TARGET_MIPS16			\
+				 && !TARGET_MIPSFROG)
 
 /* ISA has the WSBH (word swap bytes within halfwords) instruction.
    64-bit targets also provide DSBH and DSHD.  */
-#define ISA_HAS_WSBH		(mips_isa_rev >= 2 && !TARGET_MIPS16)
+#define ISA_HAS_WSBH		(mips_isa_rev >= 2 && !TARGET_MIPS16	\
+				 && !TARGET_MIPSFROG)
 
 /* ISA has data prefetch instructions.  This controls use of 'pref'.  */
 #define ISA_HAS_PREFETCH	((ISA_MIPS4				\
@@ -1282,7 +1289,8 @@ struct mips_cpu_info {
 #define ISA_HAS_TRUNC_W		(!ISA_MIPS1)
 
 /* ISA includes the MIPS32r2 seb and seh instructions.  */
-#define ISA_HAS_SEB_SEH		(mips_isa_rev >= 2 && !TARGET_MIPS16)
+#define ISA_HAS_SEB_SEH		(mips_isa_rev >= 2 && !TARGET_MIPS16	\
+				 && !TARGET_MIPSFROG)
 
 /* ISA includes the MIPS32/64 rev 2 ext and ins instructions.  */
 #define ISA_HAS_EXT_INS		((mips_isa_rev >= 2 && !TARGET_MIPS16)	\
@@ -1356,7 +1364,8 @@ struct mips_cpu_info {
 				 || TARGET_LOONGSON_2EF)
 
 /* ISA includes synci, jr.hb and jalr.hb.  */
-#define ISA_HAS_SYNCI (mips_isa_rev >= 2 && !TARGET_MIPS16)
+#define ISA_HAS_SYNCI (mips_isa_rev >= 2 && !TARGET_MIPS16		\
+		       && !TARGET_MIPSFROG)
 
 /* ISA includes sync.  */
 #define ISA_HAS_SYNC ((mips_isa >= MIPS_ISA_MIPS2 || TARGET_MIPS3900)	\
@@ -1476,11 +1485,11 @@ struct mips_cpu_info {
 %{noasmopt:-O0; O0|fno-delayed-branch:-O1; O*:-O2; :-O1} \
 %(subtarget_asm_debugging_spec) \
 %{mabi=*} %{!mabi=*: %(asm_abi_default_spec)} \
-%{mgp32} %{mgp64} %{march=*} %{mxgot:-xgot} \
+%{mgp32} %{mgp64} %{march=mipsfrog:-march=mips32r2} %{!march=mipsfrog:%{march=*}} %{mxgot:-xgot} \
 %{mfp32} %{mfpxx} %{mfp64} %{mnan=*} \
 %{modd-spreg} %{mno-odd-spreg} \
 %{mshared} %{mno-shared} \
 %{msym32} %{mno-sym32} \
-%{mtune=*}" \
+%{mtune=mipsfrog:-mtune=24kc} %{!mtune=mipsfrog:%{mtune=*}}" \
 FP_ASM_SPEC "\
 %{mmips16e2} \
 %(subtarget_asm_spec)"
-- 
2.50.1
